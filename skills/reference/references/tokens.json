{
  "$meta": {
    "name": "design-formulas default tokens",
    "version": "0.4.0",
    "source": "Design for Developers (Twarog & Moller, 2024), modernized for 2026",
    "note": "Parametric system defaults + generation recipes. A concrete palette (HEX) is produced per-brief by /design-formulas:scaffold; the color block here defines HOW to generate it.",
    "modernizations": ["oklch-generation", "fluid-clamp-type", "semantic-dark-mode", "50-950-weights", "wcag-2.2"]
  },
  "typography": {
    "base_px": 16,
    "scale_ratio": 1.618,
    "scale": {
      "h1": { "px": 50, "em": 3.125, "fluid": "clamp(2rem, 1.4rem + 3vw, 3.125rem)", "line_height": 1.15, "letter_spacing_em": -0.025 },
      "h2": { "px": 42, "em": 2.618, "fluid": "clamp(1.75rem, 1.3rem + 2.2vw, 2.625rem)", "line_height": 1.15, "letter_spacing_em": -0.025 },
      "h3": { "px": 30, "em": 1.931, "fluid": "clamp(1.5rem, 1.2rem + 1.5vw, 1.875rem)", "line_height": 1.2 },
      "h4": { "px": 25, "em": 1.618, "fluid": "clamp(1.375rem, 1.15rem + 1vw, 1.563rem)", "line_height": 1.2 },
      "h5": { "px": 19, "em": 1.194, "fluid": "clamp(1.125rem, 1.05rem + 0.4vw, 1.188rem)", "line_height": 1.25 },
      "body": { "px": 16, "em": 1.0, "fluid": "clamp(1rem, 0.95rem + 0.25vw, 1.125rem)", "line_height": 1.5 },
      "small": { "px": 11, "em": 0.667, "fluid": "0.6875rem", "line_height": 1.5, "note": "fixed — small text should not fluidly scale" }
    },
    "line_height_rules": { "body": 1.5, "body_max": 1.75, "large_max": 1.25, "header": 1.15 },
    "letter_spacing_rule": { "above_px": 64, "reduce_em": -0.025 },
    "responsive_fallback": {
      "paragraph": { "desktop_px": [18, 24], "tablet_reduction_pct": 10, "mobile_reduction_pct": 25 },
      "header": { "desktop_px": 64, "tablet_reduction_pct": 50, "mobile_reduction_pct": 20 }
    },
    "weights": ["thin", "light", "regular", "text", "medium", "bold", "black"],
    "guidance": { "default_family": "sans-serif", "headers": "serif or display", "min_button_text_px": 14, "max_bold_items_per_block": 2 }
  },
  "spacing": {
    "system": "4-point",
    "unit_px": 4,
    "steps_px": [4, 8, 12, 16, 20, 24, 28, 32, 36, 40, 44, 48],
    "tokens": { "space-1": 4, "space-2": 8, "space-3": 12, "space-4": 16, "space-5": 20, "space-6": 24, "space-8": 32, "space-10": 40, "space-12": 48 },
    "between_buttons_px": 12,
    "alt_system_5point_px": [5, 10, 15, 20, 25, 30, 35, 40, 45, 50, 55, 60]
  },
  "grid": { "columns": 12, "gutter_from_baseline": true },
  "color": {
    "harmony_default": "triadic",
    "harmonies": ["monochrome", "analogous", "complementary", "triadic", "tetradic"],
    "weight_scale": "50-950",
    "ladder": [
      { "step": 50,  "oklch_L": 0.97, "chroma_mult": 0.20, "role": "page background / subtle fill" },
      { "step": 100, "oklch_L": 0.94, "chroma_mult": 0.35, "role": "backgrounds / hover fill" },
      { "step": 200, "oklch_L": 0.87, "chroma_mult": 0.55, "role": "borders / dividers / disabled" },
      { "step": 300, "oklch_L": 0.79, "chroma_mult": 0.75, "role": "input borders / subtle text" },
      { "step": 400, "oklch_L": 0.70, "chroma_mult": 0.90, "role": "placeholder / icons" },
      { "step": 500, "oklch_L": 0.62, "chroma_mult": 1.00, "role": "base / primary interactive" },
      { "step": 600, "oklch_L": 0.54, "chroma_mult": 0.95, "role": "button hover / active" },
      { "step": 700, "oklch_L": 0.46, "chroma_mult": 0.85, "role": "strong fill / pressed" },
      { "step": 800, "oklch_L": 0.38, "chroma_mult": 0.70, "role": "body text on light / emphasis" },
      { "step": 900, "oklch_L": 0.30, "chroma_mult": 0.55, "role": "headings / high emphasis" },
      { "step": 950, "oklch_L": 0.22, "chroma_mult": 0.40, "role": "max-contrast text / titles" }
    ],
    "book_weight_mapping": "book 100-800 == ladder 100-800; 50 and 900/950 are added extremes",
    "semantic_tokens": {
      "light": { "surface-0": "neutral-50", "surface-1": "white", "surface-2": "neutral-50", "text-strong": "neutral-950", "text": "neutral-800", "text-muted": "neutral-600", "border": "neutral-200", "primary": "primary-600", "primary-hover": "primary-700" },
      "dark": { "surface-0": "neutral-950", "surface-1": "neutral-900", "surface-2": "neutral-800", "text-strong": "neutral-50", "text": "neutral-200", "text-muted": "neutral-400", "border": "neutral-700", "primary": "primary-400", "primary-hover": "primary-300" }
    },
    "contrast": {
      "standard": "WCAG 2.2",
      "aa_normal": 4.5,
      "aa_large": 3.0,
      "aa_ui_graphics": 3.0,
      "aaa_normal": 7.0,
      "large_text_def": ">=24px, or >=18.66px bold",
      "min_target_size_px": 24,
      "focus_outline": { "min_width_px": 2, "min_contrast": 3.0 },
      "apca": "emerging, not yet normative (WCAG 3.0 draft)"
    }
  },
  "components": {
    "button": { "padding_em": { "y": 1, "x": 2 }, "min_text_px": 14, "types": ["primary", "secondary", "tertiary"], "max_primary_per_view": 1 },
    "badge": {
      "small": { "padding_px": { "y": 3, "x": 8 }, "font_px": 13 },
      "medium": { "padding_px": { "y": 5, "x": 10 }, "font_px": 14 },
      "rules": { "capitalize": true, "all_caps": false, "max_words": 1, "smaller_than_buttons": true, "interactive": false }
    },
    "card": {
      "width_px": 208, "padding_px": 16, "radius_px": 4,
      "shadow": "0 1px 3px 0 rgba(0,0,0,0.1), 0 1px 3px 0 rgba(0,0,0,0.04)",
      "text": { "mobile": { "header_px": [24, 28], "body_px": [16, 18] }, "desktop": { "header_px": [34, 38], "body_px": [20, 21] } }
    },
    "toast": { "auto_dismiss_s": 5, "max_visible": 2, "close_button": true, "use_for_form_validation": false },
    "shadow_tiers": {
      "0": "0px 0px 0px 0px rgba(0,0,0,0)",
      "1": "0px 5px 10px 0px rgba(0,0,0,0.15)",
      "2": "0px 7.5px 15px 5px rgba(0,0,0,0.45)"
    },
    "icon": { "match_text_size": true, "gap_em": 1, "em_size": 1.5, "grid_px": 24, "sizes_px": [20, 24, 32, 40], "large_grid_px": 80, "nav_outline_px": 24, "button_solid_px": 20, "touch_target": { "24": 48, "20": 40 }, "format": "svg or icon-font" },
    "border": { "prefer": "subtle, reduced opacity", "active_nav": "border-bottom", "active_input": "border" },
    "checkbox": { "desktop": { "box_px": 16, "gap_px": 8, "font_px": 14 }, "mobile": { "box_px": 25, "font_px": 16 }, "states": ["unchecked", "checked", "indeterminate"] },
    "radio": { "size_px": { "small": 6, "medium": 8, "large": 20 }, "font_px": { "desktop": 16, "large": 24 }, "use_when_options_lte": 5 },
    "textarea": { "height_px": 100, "cols": 50, "rows": 4, "padding_x_px": 16, "label_input_helper_ratio": "2:1", "limit_border": "red", "states": ["focus", "valid", "disabled", "invalid"] },
    "toggle": { "desktop": { "track_px": 48, "knob_px": 24, "font_px": 14 }, "mobile": { "track_px": 48, "knob_px": 26, "font_px": 16 }, "immediate_effect": true },
    "dropdown": { "height_px": 40, "font_px": 16, "padding_px": { "y": 8, "x": 16 }, "radius_px": 4, "border_px": 1, "use_when_options_gte": 5 },
    "submit_button": { "padding_h_v_ratio": "2:1", "radius_px": 4, "padding_px": 8, "actions_position": "bottom-left" },
    "breadcrumb": { "font_px": 14, "gap_px": 8, "separators": [">", "/"], "current_is_link": false, "smaller_than_nav": true },
    "table": { "header_font_px": 14, "header_weight": "medium", "cell_padding_px": 16, "row_height_px": { "short": 32, "default": 48 }, "header_opacity": 1.0, "row_opacity": 0.6, "zebra_for_large": true, "text_align": "left", "number_align": "right", "paginate": true },
    "list": { "font_px": 14, "spacing_px": [8, 16], "capitalize_items": true },
    "tooltip": { "width_px": 208, "padding_px": 16, "radius_px": 4, "min_edge_gap_px": 16, "no_shadow": true },
    "accordion": { "header_font_px": 15, "header_opacity": 0.87, "summary_font_px": 12, "summary_opacity": 0.54, "caret_wrapper_px": 16, "caret_position": "end", "rotate_on_expand": true, "allow_multiple_open": true },
    "tabs": { "font_px": 14, "line_height_px": 24, "active_weight": 600, "inactive_weight": 400, "indicator_px": 2, "icon_container_px": 40, "icon_position": "top" },
    "avatar": { "shape": "round", "status_dot": "lower-right", "badge": "upper-right", "border": "subtle gray", "initials_fallback": true }
  }
}
